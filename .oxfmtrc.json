{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"printWidth": 120,
	"useTabs": true,
	"semi": true,
	"singleQuote": true,
	"quoteProps": "as-needed",
	"trailingComma": "all",
	"bracketSpacing": true,
	"arrowParens": "always",
	"proseWrap": "preserve",
	"endOfLine": "lf",
	"sortTailwindcss": {
		"functions": ["clsx", "cn", "twMerge", "twJoin"]
	},
	"sortImports": {
		"order": "asc",
		"groups": [
			["builtin", "external", "internal", "subpath"],
			[
				"alias-auth",
				"alias-common",
				"alias-permissions",
				"alias-users",
				"alias-database",
				"alias-generated",
				"alias-providers",
				"alias-start",
				"alias-test-helpers"
			],
			"tilde",
			["parent", "sibling", "index"],
			"style",
			"unknown"
		],
		"customGroups": [
			{ "groupName": "alias-auth", "elementNamePattern": ["#auth/**"] },
			{ "groupName": "alias-common", "elementNamePattern": ["#common/**"] },
			{ "groupName": "alias-permissions", "elementNamePattern": ["#permissions/**"] },
			{ "groupName": "alias-users", "elementNamePattern": ["#users/**"] },
			{ "groupName": "alias-database", "elementNamePattern": ["#database/**"] },
			{ "groupName": "alias-generated", "elementNamePattern": ["#generated/**"] },
			{ "groupName": "alias-providers", "elementNamePattern": ["#providers/**"] },
			{ "groupName": "alias-start", "elementNamePattern": ["#start/**"] },
			{ "groupName": "alias-test-helpers", "elementNamePattern": ["#test-helpers/**"] },
			{ "groupName": "tilde", "elementNamePattern": ["~/**"] }
		]
	},
	"sortPackageJson": false,
	"ignorePatterns": ["**/.adonisjs/**", "routeTree.gen.ts", "node_modules/**", "dist/**", "build/**", "*.yml"]
}
