{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"printWidth": 120,
	"useTabs": true,
	"semi": true,
	"singleQuote": true,
	"quoteProps": "as-needed",
	"trailingComma": "all",
	"bracketSpacing": true,
	"arrowParens": "always",
	"proseWrap": "preserve",
	"endOfLine": "lf",
	"sortTailwindcss": {
		"functions": ["clsx", "cn", "twMerge", "twJoin"]
	},
	"sortImports": {
		"order": "asc",
		"groups": [
			["builtin", "external", "internal", "subpath"],
			[
				"alias-abilities",
				"alias-config",
				"alias-controllers",
				"alias-database",
				"alias-events",
				"alias-exceptions",
				"alias-listeners",
				"alias-mails",
				"alias-middleware",
				"alias-models",
				"alias-policies",
				"alias-providers",
				"alias-services",
				"alias-start",
				"alias-test-helpers",
				"alias-tests",
				"alias-types",
				"alias-validators",
				"alias-utils"
			],
			"tilde",
			["parent", "sibling", "index"],
			"style",
			"unknown"
		],
		"customGroups": [
			{ "groupName": "alias-abilities", "elementNamePattern": ["#abilities/**"] },
			{ "groupName": "alias-config", "elementNamePattern": ["#config/**"] },
			{ "groupName": "alias-controllers", "elementNamePattern": ["#controllers/**"] },
			{ "groupName": "alias-database", "elementNamePattern": ["#database/**"] },
			{ "groupName": "alias-events", "elementNamePattern": ["#events/**"] },
			{ "groupName": "alias-exceptions", "elementNamePattern": ["#exceptions/**"] },
			{ "groupName": "alias-listeners", "elementNamePattern": ["#listeners/**"] },
			{ "groupName": "alias-mails", "elementNamePattern": ["#mails/**"] },
			{ "groupName": "alias-middleware", "elementNamePattern": ["#middleware/**"] },
			{ "groupName": "alias-models", "elementNamePattern": ["#models/**"] },
			{ "groupName": "alias-policies", "elementNamePattern": ["#policies/**"] },
			{ "groupName": "alias-providers", "elementNamePattern": ["#providers/**"] },
			{ "groupName": "alias-services", "elementNamePattern": ["#services/**"] },
			{ "groupName": "alias-start", "elementNamePattern": ["#start/**"] },
			{ "groupName": "alias-test-helpers", "elementNamePattern": ["#test-helpers/**"] },
			{ "groupName": "alias-tests", "elementNamePattern": ["#tests/**"] },
			{ "groupName": "alias-types", "elementNamePattern": ["#types/**"] },
			{ "groupName": "alias-validators", "elementNamePattern": ["#validators/**"] },
			{ "groupName": "alias-utils", "elementNamePattern": ["#utils/**"] },
			{ "groupName": "tilde", "elementNamePattern": ["~/**"] }
		]
	},
	"sortPackageJson": false,
	"ignorePatterns": ["**/.adonisjs/**", "routeTree.gen.ts", "node_modules/**", "dist/**", "build/**", "*.yml"]
}
