		"node": ">=24.0.0"
	},
	"pnpm": {
		"overrides": {
			"eslint-plugin-react>eslint": "$eslint"
		}
	},
	"hotHook": {
		"boundaries": [
			"./app/controllers/**/*.ts",
			"./app/middleware/*.ts"
		]
	}
