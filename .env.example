# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# Database
DB_CONNECTION=pg
DB_HOST=${HOST}
DB_PGPASSWORD=
DB_PORT=5432
DB_USER=
DB_DATABASE=
DB_PASSWORD=

# Default admin
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=

# Mail
MAIL_MAILER=smtp
MAIL_FROM_NAME=Your name
MAIL_FROM_ADDRESS=app@yourdomain.com
SMTP_HOST=localhost
SMTP_PORT=1025