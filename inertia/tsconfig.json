{
	"extends": "@adonisjs/tsconfig/tsconfig.client.json",
	"compilerOptions": {
		"module": "ESNext",
		"jsx": "react-jsx",
		"rewriteRelativeImportExtensions": true,
		"paths": {
			"~/*": ["./*"],
			"#generated/*": ["../.adonisjs/client/*"]
		}
	},
	"include": ["./**/*.ts", "./**/*.tsx", "../.adonisjs/client/**/*.ts", "../.adonisjs/server/**/*.ts"]
}
